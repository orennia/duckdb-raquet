# name: test/sql/read_raster_metadata.test
# description: End-to-end metadata enrichment via read_raster() — verifies the
#              GDAL plumbing (palette colortable, stats, top-level width/height)
#              in both v0.1.0 ("v0") and v0.5.0 outputs.
# group: [raquet]

require raquet

require json

# =============================================================================
# Fixture: test/data/test_palette.tif — 16×16 uint8 single-band raster with
# a 4-entry color table (PaletteIndex), nodata=0, EPSG:4326. Deterministic
# (random pixel values seeded with numpy seed=42).
# =============================================================================

# v0.5.0 (default format) — top-level width/height, per-band colortable + STATISTICS_*
statement ok
CREATE TABLE r_v050 AS
SELECT metadata FROM read_raster('test/data/test_palette.tif')
WHERE block = 0

# Top-level width / height come from GDAL XSize / YSize (16x16 fixture).
query II
SELECT json_extract(metadata, '$.width')::INTEGER,
       json_extract(metadata, '$.height')::INTEGER
FROM r_v050
----
16	16

# colorinterp captured from GDAL — palette band.
query I
SELECT json_extract_string(metadata, '$.bands[0].colorinterp') FROM r_v050
----
palette

# Color table entries match the fixture's 4-entry palette.
query I
SELECT json_array_length(json_extract(metadata, '$.bands[0].colortable."1"'))
FROM r_v050
----
4

query IIII
SELECT json_extract(metadata, '$.bands[0].colortable."1"[0]')::INTEGER,
       json_extract(metadata, '$.bands[0].colortable."1"[1]')::INTEGER,
       json_extract(metadata, '$.bands[0].colortable."1"[2]')::INTEGER,
       json_extract(metadata, '$.bands[0].colortable."1"[3]')::INTEGER
FROM r_v050
----
12	68	28	255

# v0.5.0 STATISTICS_* keys present and well-formed.
query I
SELECT json_extract(metadata, '$.bands[0].STATISTICS_MAXIMUM')::DOUBLE > 0
FROM r_v050
----
true

# STATISTICS_VALID_PERCENT is in [0, 100].
query I
SELECT json_extract(metadata, '$.bands[0].STATISTICS_VALID_PERCENT')::DOUBLE
       BETWEEN 0 AND 100
FROM r_v050
----
true

statement ok
DROP TABLE r_v050

# =============================================================================
# Legacy format ('v0') — v0.1.0 shape with stats.approximated_stats and
# colortable on the band.
# =============================================================================

statement ok
CREATE TABLE r_v0 AS
SELECT metadata FROM read_raster('test/data/test_palette.tif', format='v0')
WHERE block = 0

# v0.1.0 marker
query I
SELECT json_extract_string(metadata, '$.version') FROM r_v0
----
0.1.0

# Bounds (4-element WGS84 array) and center (3-element array) populated.
query II
SELECT json_array_length(json_extract(metadata, '$.bounds')),
       json_array_length(json_extract(metadata, '$.center'))
FROM r_v0
----
4	3

# Top-level width/height/num_pixels mirror the source raster.
query III
SELECT json_extract(metadata, '$.width')::INTEGER,
       json_extract(metadata, '$.height')::INTEGER,
       json_extract(metadata, '$.num_pixels')::BIGINT
FROM r_v0
----
16	16	256

# Single-band → nodata is a scalar (not an array).
query I
SELECT json_extract(metadata, '$.nodata')::DOUBLE FROM r_v0
----
0.0

# Per-band colortable populated (4 RGBA entries from the fixture).
query I
SELECT json_array_length(json_extract(metadata, '$.bands[0].colortable."1"'))
FROM r_v0
----
4

# Stats by default are approximate.
query I
SELECT json_extract(metadata, '$.bands[0].stats.approximated_stats')::BOOLEAN
FROM r_v0
----
true

# Stats fields the CARTO platform color-ramp consumer reads.
query I
SELECT
  json_extract(metadata, '$.bands[0].stats.count') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.min') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.max') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.mean') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.stddev') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.sum') IS NOT NULL AND
  json_extract(metadata, '$.bands[0].stats.sum_squares') IS NOT NULL
FROM r_v0
----
true

statement ok
DROP TABLE r_v0

# =============================================================================
# approx=false flips approximated_stats and routes through GDAL's exact path.
# =============================================================================

statement ok
CREATE TABLE r_v0_exact AS
SELECT metadata FROM read_raster('test/data/test_palette.tif',
                                 format='v0', approx=false)
WHERE block = 0

query I
SELECT json_extract(metadata, '$.bands[0].stats.approximated_stats')::BOOLEAN
FROM r_v0_exact
----
false

statement ok
DROP TABLE r_v0_exact
