# name: test/sql/v050_features.test
# description: Test v0.5.0 metadata extensions (top-level width/height, per-band
#              colortable + STATISTICS_*) emitted by read_raster() default format
# group: [raquet]

require raquet

require json

# =============================================================================
# v0.5.0 raquet metadata shape (post enrichment) — top-level width/height
# and per-band colortable + STATISTICS_* fields.
# =============================================================================

# Representative v0.5.0 metadata blob with the new fields populated.
statement ok
CREATE TABLE v050_meta AS SELECT '{
  "file_format":"raquet",
  "version":"0.5.0",
  "crs":"EPSG:3857",
  "bounds":[5.866944,47.270111,15.041931,55.058201],
  "bounds_crs":"EPSG:4326",
  "width":64293,
  "height":86760,
  "compression":"gzip",
  "tiling":{
    "scheme":"quadbin","block_width":256,"block_height":256,
    "min_zoom":4,"max_zoom":13,"pixel_zoom":21,"num_blocks":53423
  },
  "bands":[
    {"name":"band_1","type":"uint8","nodata":0,"colorinterp":"palette",
     "colortable":{"0":[0,0,0,0],"1":[12,68,28,255],"2":[200,170,90,255]},
     "STATISTICS_MINIMUM":0,"STATISTICS_MAXIMUM":12,"STATISTICS_MEAN":4.7,
     "STATISTICS_STDDEV":2.3,"STATISTICS_VALID_PERCENT":98.4}
  ]
}'::VARCHAR AS metadata

# Top-level: width / height (new — required by v0.5.0 spec, were missing pre-enrichment)
query II
SELECT json_extract(metadata, '$.width')::INTEGER,
       json_extract(metadata, '$.height')::INTEGER
FROM v050_meta
----
64293	86760

# Per-band colortable for palette band
query I
SELECT json_array_length(json_extract(metadata, '$.bands[0].colortable."1"')) FROM v050_meta
----
4

# Per-band STATISTICS_* keys are spec-compliant (PAM/GDAL convention).
query IIIII
SELECT json_extract(metadata, '$.bands[0].STATISTICS_MINIMUM')::DOUBLE,
       json_extract(metadata, '$.bands[0].STATISTICS_MAXIMUM')::DOUBLE,
       json_extract(metadata, '$.bands[0].STATISTICS_MEAN')::DOUBLE,
       json_extract(metadata, '$.bands[0].STATISTICS_STDDEV')::DOUBLE,
       json_extract(metadata, '$.bands[0].STATISTICS_VALID_PERCENT')::DOUBLE
FROM v050_meta
----
0.0	12.0	4.7	2.3	98.4

# STATISTICS_VALID_PERCENT is between 0 and 100
query I
SELECT json_extract(metadata, '$.bands[0].STATISTICS_VALID_PERCENT')::DOUBLE
       BETWEEN 0 AND 100
FROM v050_meta
----
true

# raquet_parse_metadata still works on the enriched shape (no regression).
query IIIIIII
SELECT (raquet_parse_metadata(metadata)).compression,
       (raquet_parse_metadata(metadata)).block_width,
       (raquet_parse_metadata(metadata)).block_height,
       (raquet_parse_metadata(metadata)).min_zoom,
       (raquet_parse_metadata(metadata)).max_zoom,
       (raquet_parse_metadata(metadata)).num_bands,
       (raquet_parse_metadata(metadata)).band_layout
FROM v050_meta
----
gzip	256	256	4	13	1	sequential

statement ok
DROP TABLE v050_meta

# =============================================================================
# Multi-band v0.5.0 with no palette: colortable is omitted (not "null")
# per the v0.5.0 spec — the key only appears when a palette exists.
# =============================================================================

statement ok
CREATE TABLE v050_meta_rgb AS SELECT '{
  "file_format":"raquet","version":"0.5.0","crs":"EPSG:3857",
  "bounds":[-180,-90,180,90],"bounds_crs":"EPSG:4326",
  "width":2048,"height":1024,
  "compression":"gzip",
  "tiling":{"scheme":"quadbin","block_width":256,"block_height":256,
            "min_zoom":0,"max_zoom":3,"pixel_zoom":11,"num_blocks":85},
  "bands":[
    {"name":"red","type":"uint8","colorinterp":"red",
     "STATISTICS_MINIMUM":0,"STATISTICS_MAXIMUM":255,"STATISTICS_MEAN":127,
     "STATISTICS_STDDEV":50,"STATISTICS_VALID_PERCENT":100},
    {"name":"green","type":"uint8","colorinterp":"green",
     "STATISTICS_MINIMUM":0,"STATISTICS_MAXIMUM":255,"STATISTICS_MEAN":110,
     "STATISTICS_STDDEV":40,"STATISTICS_VALID_PERCENT":100},
    {"name":"blue","type":"uint8","colorinterp":"blue",
     "STATISTICS_MINIMUM":0,"STATISTICS_MAXIMUM":255,"STATISTICS_MEAN":90,
     "STATISTICS_STDDEV":35,"STATISTICS_VALID_PERCENT":100}
  ]
}'::VARCHAR AS metadata

query I
SELECT (raquet_parse_metadata(metadata)).num_bands FROM v050_meta_rgb
----
3

# Non-palette bands have no colortable key
query I
SELECT json_type(metadata, '$.bands[0].colortable') FROM v050_meta_rgb
----
NULL

# All bands carry STATISTICS_* keys
query III
SELECT json_extract(metadata, '$.bands[0].STATISTICS_MEAN')::DOUBLE,
       json_extract(metadata, '$.bands[1].STATISTICS_MEAN')::DOUBLE,
       json_extract(metadata, '$.bands[2].STATISTICS_MEAN')::DOUBLE
FROM v050_meta_rgb
----
127.0	110.0	90.0

statement ok
DROP TABLE v050_meta_rgb
