# name: test/sql/v01_features.test
# description: Test v0.1.0 metadata shape (legacy "v0" format) emitted by read_raster(format='v0')
# group: [raquet]

require raquet

require json

# =============================================================================
# v0.1.0 raquet metadata shape (matches Python `raquet 0.2.5` legacy output).
#
# These tests use a hand-crafted JSON string matching what to_json_v0() now
# emits. They cover the parser's ability to round-trip the new fields and the
# JSON shape consumers (CARTO maps-api / Builder) will see.
# =============================================================================

# A representative v0.1.0 metadata blob: 2-band uint8 raster with one palette
# band (with a small color table), one non-palette band, both with stats.
statement ok
CREATE TABLE v01_meta AS SELECT '{
  "version":"0.1.0",
  "compression":"gzip",
  "block_width":512,
  "block_height":512,
  "minresolution":4,
  "maxresolution":13,
  "pixel_resolution":22,
  "num_blocks":53423,
  "bounds":[5.866944,47.270111,15.041931,55.058201],
  "center":[10.454437,51.164156,4],
  "width":64293,
  "height":86760,
  "num_pixels":5578063080,
  "block_resolution":13,
  "nodata":[0,null],
  "bands":[
    {"name":"band_1","type":"uint8","colorinterp":"palette",
     "colortable":{"0":[0,0,0,0],"1":[255,0,0,255],"2":[0,255,0,255]},
     "stats":{"count":4123456,"min":0,"max":12,"mean":4.7,"stddev":2.3,
              "sum":19380243.2,"sum_squares":113194824.6,
              "approximated_stats":true}},
    {"name":"band_2","type":"uint8","colorinterp":"gray","colortable":null,
     "stats":{"count":4123456,"min":0,"max":255,"mean":127.5,"stddev":40.0,
              "sum":525740640.0,"sum_squares":73639699392.0,
              "approximated_stats":true}}
  ]
}'::VARCHAR AS metadata

# Top-level: version is the v0.1.0 marker (CARTO frontend reads this)
query I
SELECT json_extract_string(metadata, '$.version') FROM v01_meta
----
0.1.0

# Top-level: bounds is a 4-element [W,S,E,N] array
query I
SELECT json_array_length(json_extract(metadata, '$.bounds')) FROM v01_meta
----
4

# Top-level: center is a 3-element [lon,lat,min_zoom] array
query I
SELECT json_array_length(json_extract(metadata, '$.center')) FROM v01_meta
----
3

# Top-level: width and height (new in this release)
query II
SELECT json_extract(metadata, '$.width')::INTEGER,
       json_extract(metadata, '$.height')::INTEGER
FROM v01_meta
----
64293	86760

# Top-level: num_pixels and block_resolution (new in this release)
query II
SELECT json_extract(metadata, '$.num_pixels')::BIGINT,
       json_extract(metadata, '$.block_resolution')::INTEGER
FROM v01_meta
----
5578063080	13

# Top-level: nodata is array form (multi-band raster)
query I
SELECT json_array_length(json_extract(metadata, '$.nodata')) FROM v01_meta
----
2

# Per-band: colortable populated for the palette band
query I
SELECT json_extract(metadata, '$.bands[0].colorinterp')::VARCHAR FROM v01_meta
----
"palette"

query I
SELECT json_array_length(json_extract(metadata, '$.bands[0].colortable."1"')) FROM v01_meta
----
4

# Per-band: stats include the v0.1.0 keys consumers depend on
query I
SELECT json_extract(metadata, '$.bands[0].stats.count')::BIGINT > 0 FROM v01_meta
----
true

query I
SELECT json_extract(metadata, '$.bands[0].stats.approximated_stats')::BOOLEAN FROM v01_meta
----
true

query IIIIII
SELECT json_extract(metadata, '$.bands[0].stats.min')::DOUBLE,
       json_extract(metadata, '$.bands[0].stats.max')::DOUBLE,
       json_extract(metadata, '$.bands[0].stats.mean')::DOUBLE,
       json_extract(metadata, '$.bands[0].stats.stddev')::DOUBLE,
       json_extract(metadata, '$.bands[0].stats.sum')::DOUBLE,
       json_extract(metadata, '$.bands[0].stats.sum_squares')::DOUBLE
FROM v01_meta
----
0.0	12.0	4.7	2.3	19380243.2	113194824.6

# Per-band: non-palette band has colortable=null (key still present)
query I
SELECT json_type(metadata, '$.bands[1].colortable') FROM v01_meta
----
NULL

# raquet_parse_metadata round-trips the v0.1.0 shape (parses object-form bands,
# extracts compression/zoom/block sizes that the existing struct exposes).
query IIIIIII
SELECT (raquet_parse_metadata(metadata)).compression,
       (raquet_parse_metadata(metadata)).block_width,
       (raquet_parse_metadata(metadata)).block_height,
       (raquet_parse_metadata(metadata)).min_zoom,
       (raquet_parse_metadata(metadata)).max_zoom,
       (raquet_parse_metadata(metadata)).num_bands,
       (raquet_parse_metadata(metadata)).band_layout
FROM v01_meta
----
gzip	512	512	4	13	2	sequential

# Single-band v0.1.0 raster: nodata is emitted as a scalar (not an array).
statement ok
CREATE TABLE v01_meta_single AS SELECT '{
  "version":"0.1.0","compression":null,"block_width":256,"block_height":256,
  "minresolution":0,"maxresolution":10,"pixel_resolution":18,"num_blocks":1234,
  "bounds":[-180,-90,180,90],"center":[0,0,0],"width":1024,"height":512,
  "num_pixels":524288,"block_resolution":10,"nodata":-9999.0,
  "bands":[
    {"name":"band_1","type":"int16","colorinterp":"gray","colortable":null,
     "stats":null}
  ]
}'::VARCHAR AS metadata

# Single-band: nodata is a scalar, not an array
query I
SELECT json_type(metadata, '$.nodata') FROM v01_meta_single
----
DOUBLE

query I
SELECT json_extract(metadata, '$.nodata')::DOUBLE FROM v01_meta_single
----
-9999.0

query I
SELECT (raquet_parse_metadata(metadata)).num_bands FROM v01_meta_single
----
1

statement ok
DROP TABLE v01_meta

statement ok
DROP TABLE v01_meta_single
